# このファイルを .env.slack.local という名前で複製し、値を設定します。
# .env.slack.local は Git の対象外（*.local）なので、秘密鍵は共有されません。

# Slack Bot の秘密鍵。画像送信には files:write 権限が必要です。
SLACK_BOT_TOKEN=xoxb-your-bot-token

# 送信先の Slack チャンネル ID。チャンネル名ではなく C などで始まる ID です。
SLACK_CHANNEL_ID=C0123456789

# 表示するプロジェクト名。
SLACK_PROJECT_NAME=Pachi Tracker

# Slackからの指示を許可する本人のユーザーIDです。Uで始まるIDを1つだけ指定します。
# このID以外の投稿と、codex: / 指示: で始まらない投稿は実行しません。
SLACK_ALLOWED_USER_ID=U0123456789

# 特定のスレッドへまとめたい場合だけ設定します。
# SLACK_THREAD_TS=1234567890.123456

# 文章通知だけなら Incoming Webhook も使えます。
# Bot Token がある場合は Bot Token を優先します。Webhook だけではローカル画像を送信できません。
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
